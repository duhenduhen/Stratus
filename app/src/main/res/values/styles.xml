<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="PreferenceThemeOverlay.Stratus" parent="PreferenceThemeOverlay.v14.Material">
        <item name="preferenceFragmentListStyle">@style/PreferenceFragmentList.Stratus</item>
        <item name="preferenceCategoryTitleTextAppearance">@style/TextAppearance.Stratus.PreferenceCategory</item>
        <item name="switchPreferenceCompatStyle">@style/Preference.Stratus.SwitchPreferenceCompat</item>
        <item name="preferenceCategoryStyle">@style/Preference.Stratus.Category</item>
    </style>

    <style name="PreferenceFragmentList.Stratus" parent="PreferenceFragmentList">
        <item name="android:divider">@null</item>
        <item name="android:overScrollMode">never</item>
        <item name="android:paddingTop">0dp</item>
        <item name="android:paddingBottom">24dp</item>
    </style>

    <style name="TextAppearance.Stratus.PreferenceCategory" parent="TextAppearance.Material3.TitleSmall">
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">?attr/colorPrimary</item>
    </style>

    <style name="TextAppearance.Stratus.CollapsingHeader" parent="TextAppearance.Material3.DisplaySmall">
        <item name="android:textSize">40sp</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <style name="TextAppearance.Stratus.CollapsingHeaderSmall" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <style name="Preference.Stratus.SwitchPreferenceCompat" parent="Preference.SwitchPreferenceCompat.Material">
        <item name="allowDividerAbove">false</item>
        <item name="allowDividerBelow">false</item>
        <item name="android:layout">@layout/preference_switch_material3</item>
        <item name="android:widgetLayout">@layout/preference_widget_material3_switch</item>
        <item name="iconSpaceReserved">false</item>
        <item name="singleLineTitle">false</item>
    </style>

    <style name="Preference.Stratus.Category" parent="Preference.Category.Material">
        <item name="allowDividerAbove">false</item>
        <item name="allowDividerBelow">false</item>
        <item name="iconSpaceReserved">false</item>
    </style>

</resources>
